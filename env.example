# Bitbucket Configuration
BITBUCKET_BASE_URL=https://bitbucket.org
BITBUCKET_SERVER_TYPE=cloud

# Authentication (choose one method)
# OAuth (Cloud)
BITBUCKET_OAUTH_CLIENT_ID=your_oauth_client_id
BITBUCKET_OAUTH_CLIENT_SECRET=your_oauth_client_secret
BITBUCKET_OAUTH_ACCESS_TOKEN=your_oauth_access_token
BITBUCKET_OAUTH_REFRESH_TOKEN=your_oauth_refresh_token

# App Password (Cloud)
BITBUCKET_USERNAME=your_username
BITBUCKET_APP_PASSWORD=your_app_password

# API Token (Data Center)
BITBUCKET_API_TOKEN=your_api_token

# Basic Auth (Data Center)
BITBUCKET_BASIC_USERNAME=your_username
BITBUCKET_BASIC_PASSWORD=your_password

# Timeouts (milliseconds)
BITBUCKET_READ_TIMEOUT=2000
BITBUCKET_WRITE_TIMEOUT=5000
BITBUCKET_CONNECT_TIMEOUT=10000

# Rate Limiting
BITBUCKET_REQUESTS_PER_MINUTE=60
BITBUCKET_BURST_LIMIT=10
BITBUCKET_RETRY_AFTER=1000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# MCP Server
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=localhost

# Development
NODE_ENV=development
