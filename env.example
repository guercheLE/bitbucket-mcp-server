# Bitbucket MCP Server Environment Configuration
# Copy this file to .env and configure your values

# ============================================================================
# Node Environment
# ============================================================================
NODE_ENV=development

# ============================================================================
# Server Configuration
# ============================================================================
SERVER_HOST=localhost
SERVER_PORT=3000

# ============================================================================
# Bitbucket Configuration
# ============================================================================
# Bitbucket server URL (required for most operations)
BITBUCKET_SERVER_URL=https://bitbucket.example.com

# Authentication type (oauth2, personal-token, app-password, basic)
BITBUCKET_AUTH_TYPE=oauth2

# OAuth2 Configuration
BITBUCKET_AUTH_CLIENT_ID=your-oauth-client-id
BITBUCKET_AUTH_CLIENT_SECRET=your-oauth-client-secret
BITBUCKET_AUTH_REDIRECT_URI=http://localhost:3000/callback

# Personal Access Token (alternative to OAuth2)
BITBUCKET_AUTH_TOKEN=your-personal-access-token

# App Password (for Data Center)
BITBUCKET_AUTH_USERNAME=your-username
BITBUCKET_AUTH_PASSWORD=your-app-password

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=logs/bitbucket-mcp-server.log

# ============================================================================
# Cache Configuration
# ============================================================================
CACHE_TYPE=memory
CACHE_TTL=300
CACHE_MAX_SIZE=100

# Redis Configuration (if using Redis cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# Security Configuration
# ============================================================================
CORS_ORIGIN=*
CORS_CREDENTIALS=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ============================================================================
# Performance Configuration
# ============================================================================
REQUEST_TIMEOUT=10000
MAX_RETRIES=3
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60000

# ============================================================================
# Health Check Configuration
# ============================================================================
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# ============================================================================
# Metrics Configuration
# ============================================================================
METRICS_ENABLED=true
METRICS_INTERVAL=60000

# ============================================================================
# Development Configuration
# ============================================================================
DEBUG=false
VERBOSE=false

# ============================================================================
# Testing Configuration
# ============================================================================
TEST_TIMEOUT=30000
TEST_COVERAGE_THRESHOLD=80
