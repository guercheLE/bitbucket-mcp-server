{
  "name": "bitbucket-mcp-server",
  "version": "1.0.0",
  "description": "Comprehensive Bitbucket MCP Server with 250+ endpoints supporting both Data Center and Cloud",
  "main": "dist/server/index.js",
  "bin": {
    "bitbucket-mcp": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "build:watch": "tsc --watch",
    "dev": "tsx src/server/index.ts",
    "start": "node dist/server/index.js",
    "cli": "tsx src/client/cli/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest tests/unit",
    "test:integration": "jest tests/integration",
    "test:contract": "jest tests/contract",
    "lint": "eslint src --ext .ts,.tsx --quiet",
    "lint:verbose": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write src tests",
    "clean": "rimraf dist",
    "prepare": "husky",
    "postinstall": "npm run build",
    "publish:test": "node scripts/publish.js --test",
    "publish:prod": "node scripts/publish.js --production",
    "publish:check": "npm pack --dry-run",
    "prepublishOnly": "npm run build && npm test",
    "prepack": "npm run build",
    "validate:constitution": "node scripts/validate-constitution.js",
    "validate:auth-security": "node scripts/validate-auth-security.js",
    "version": "npm run build && git add -A && git commit -m \"chore: bump version\""
  },
  "keywords": [
    "bitbucket",
    "mcp",
    "model-context-protocol",
    "api",
    "server",
    "datacenter",
    "cloud",
    "git",
    "repository",
    "pull-request",
    "issues",
    "pipelines"
  ],
  "author": "Bitbucket MCP Server Team",
  "license": "LGPL-3.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cache": "^4.1.3",
    "axios": "^1.6.0",
    "boxen": "^7.0.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^11.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "express-rate-limit": "^8.1.0",
    "figlet": "^1.6.0",
    "gradient-string": "^2.0.2",
    "helmet": "^7.2.0",
    "i18next": "^23.7.0",
    "i18next-fs-backend": "^2.3.0",
    "i18next-http-middleware": "^3.5.0",
    "inquirer": "^9.2.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "node-cache": "^5.1.2",
    "opossum": "^8.0.0",
    "ora": "^7.0.1",
    "rate-limiter-flexible": "^3.0.0",
    "redis": "^5.8.2",
    "table": "^6.8.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/figlet": "^1.5.6",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.8",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.0",
    "@types/redis": "^4.0.10",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "cross-env": "^10.0.0",
    "eslint": "^8.55.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.1.6",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guercheLE/bitbucket-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/guercheLE/bitbucket-mcp-server/issues"
  },
  "homepage": "https://github.com/guercheLE/bitbucket-mcp-server#readme"
}
