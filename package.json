{
  "name": "bitbucket-mcp-server",
  "version": "1.0.0",
  "description": "Bitbucket MCP Server with integrated CLI client supporting both Cloud and Data Center",
  "main": "dist/server/index.js",
  "bin": {
    "bitbucket-mcp": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "format:check": "prettier --check src/**/*.ts",
    "type-check": "tsc --noEmit",
    "clean": "if exist dist rmdir /s /q dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "bitbucket",
    "mcp",
    "model-context-protocol",
    "cli",
    "api",
    "cloud",
    "datacenter"
  ],
  "author": "Bitbucket MCP Server Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.4.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.6.2",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guercheLE/bitbucket-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/guercheLE/bitbucket-mcp-server/issues"
  },
  "homepage": "https://github.com/guercheLE/bitbucket-mcp-server#readme"
}
